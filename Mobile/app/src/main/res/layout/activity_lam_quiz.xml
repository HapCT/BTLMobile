<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#F0F2F5">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="15dp"
        app:cardElevation="4dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvSoCauHoi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Câu hỏi 1/10"
                android:textColor="#1976D2"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNoiDungCauHoi"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Nội dung câu hỏi sẽ hiển thị ở đây?"
                android:textSize="20sp"
                android:textColor="#212121"
                android:textStyle="bold" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <RadioGroup
        android:id="@+id/rgDapAn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RadioButton
            android:id="@+id/rbA"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/selector_quiz_option"
            android:button="@null"
            android:padding="16dp"
            android:text="Đáp án A"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbB"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/selector_quiz_option"
            android:button="@null"
            android:padding="16dp"
            android:text="Đáp án B"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbC"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:background="@drawable/selector_quiz_option"
            android:button="@null"
            android:padding="16dp"
            android:text="Đáp án C"
            android:textSize="16sp" />

        <RadioButton
            android:id="@+id/rbD"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/selector_quiz_option"
            android:button="@null"
            android:padding="16dp"
            android:text="Đáp án D"
            android:textSize="16sp" />
    </RadioGroup>

    <Button
        android:id="@+id/btnTiepTheo"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="CÂU TIẾP THEO"
        android:textSize="18sp"
        android:textStyle="bold"
        android:backgroundTint="#1976D2"
        android:textColor="@color/white"
        app:cornerRadius="10dp" />

</LinearLayout>